{
  "name": "polymarket-5m",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun --watch src/index.ts",
    "dev:all": "concurrently \"bun run src/index.ts\" \"cd src/web && bun run dev\"",
    "build:web": "cd src/web && bun run build",
    "dashboard": "bun src/ui/cli.tsx",
    "build": "bun build ./src/index.ts --outdir ./dist --target bun",
    "lint": "bun x eslint src/**",
    "format": "bun x prettier --write src/**"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "latest",
    "concurrently": "^9.2.1",
    "eslint": "^10.2.0",
    "eslint-plugin-react": "^7.37.5",
    "prettier": "^3.8.3",
    "react-devtools-core": "^7.0.1",
    "typescript-eslint": "^8.58.2"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@types/react": "^19.2.14",
    "ink": "^7.0.0",
    "react": "^19.2.5"
  }
}
