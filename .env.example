# Polymarket Monitor - Environment Variables

# Trading mode: "live" or "dryrun" (default: dryrun)
TRADING_MODE=dryrun

# SeriesIds cripto para monitorar em paralelo (até 8, separados por vírgula)
# seriesId é imutável entre os mercados de 5 minutos de cada série
SERIES_IDS=1,2,3

# API URLs (defaults already set in config.ts)
# GAMMA_BASE_URL=https://gamma-api.polymarket.com
# CLOB_BASE_URL=https://clob.polymarket.com
# WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market

# CLOB Credentials (required for TRADING_MODE=live)
PRIVATE_KEY=
CLOB_API_KEY=
CLOB_API_SECRET=
CLOB_API_PASSPHRASE=
PROXY_WALLET=
